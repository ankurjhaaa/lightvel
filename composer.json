{
  "name": "lightvel/lightvel",
  "description": "Lightweight reactive Laravel package inspired by Livewire",
  "version": "1.2.0",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Lightvel\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Lightvel\\LightvelServiceProvider"
      ]
    }
  },
  "require": {
    "php": "^8.2",
    "illuminate/console": "^11.0|^12.0|^13.0",
    "illuminate/filesystem": "^11.0|^12.0|^13.0",
    "illuminate/support": "^11.0|^12.0|^13.0",
    "illuminate/view": "^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
